// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Memo {
  id         String   @id @default(cuid())
  title      String
  date       String?  // 日付はオプション
  tags       Tag[]    @relation("MemoTags")
  body       String?
  embedding  Json?    // 埋め込みベクトル（Gemini embedding-001の場合、768次元、JSON配列で保存）
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Tag {
  id          String @id @default(cuid())
  name        String @unique
  description String?
  memos       Memo[] @relation("MemoTags")
}

model TagExpression {
  id        String   @id @default(cuid())
  orTerms   Json      // TagExpressionTerm[]をJSONで保存
  name      String?   // 保存されない場合はnull
  color     String?
  icon      String?
  createdAt DateTime? 
  updatedAt DateTime? 
}